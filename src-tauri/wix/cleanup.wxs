<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX fragment — uninstall cleanup prompt
  卸载时弹窗询问用户是否删除用户数据（API Key、设置等）

  CustomAction "CleanupUserDataPrompt":
    - 仅在卸载时触发 (REMOVE="ALL")
    - 通过 PowerShell + WScript.Shell Popup 弹窗
    - 用户选"是" → 删除 %LOCALAPPDATA%\com.hologram.app
    - 用户选"否" → 保留数据
    - Return="ignore": 清理失败不阻止卸载
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Fragment>
        <CustomAction
            Id="CleanupUserDataPrompt"
            Impersonate="yes"
            Execute="deferred"
            Return="ignore"
            Directory="SystemFolder"
            ExeCommand='powershell.exe -NoProfile -WindowStyle Hidden -EncodedCommand '
        />

        <InstallExecuteSequence>
            <!-- Only prompt during full uninstall, not during upgrade -->
            <Custom Action="CleanupUserDataPrompt" After="RemoveFiles"><![CDATA[REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE]]></Custom>
        </InstallExecuteSequence>
    </Fragment>
</Wix>

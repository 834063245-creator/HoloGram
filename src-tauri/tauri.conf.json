{
  "productName": "全息观测站",
  "identifier": "com.hologram.hg",
  "version": "0.2.0",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev --prefix ../src-ui",
    "beforeBuildCommand": "npm run build --prefix ../src-ui"
  },
  "app": {
    "windows": [
      {
        "title": "全息观测站",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "resources": ["../engine/target/release/hologram-engine.exe"],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "fragmentPaths": ["wix/cleanup.wxs"]
      }
    }
  }
}
